<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Internal domains (comma-separated) - emails from these domains will not be processed -->
    <add key="InternalDomains" value="yourdomain.com,internal.local,contoso.com" />
    
    <!-- Log file path - where to write agent logs -->
    <add key="LogFilePath" value="%ProgramData%\Microsoft\Exchange\Logs\UrlToTextAgent.log" />
    
    <!-- Enable/disable logging - set to false to disable logging -->
    <add key="EnableLogging" value="true" />
    
    <!-- Log level - DEBUG, INFO, WARNING, ERROR, SUCCESS -->
    <!-- DEBUG: All messages, INFO: General information, WARNING: Potential issues, ERROR: Errors only -->
    <add key="LogLevel" value="INFO" />
    
    <!-- Enable Windows Event Log for errors - set to true to log errors to Windows Event Log -->
    <add key="EnableEventLog" value="true" />
    
    <!-- Skip signed emails - set to true to skip processing digitally signed emails -->
    <add key="SkipSignedEmails" value="true" />
    
    <!-- Skip encrypted emails - set to true to skip processing encrypted emails -->
    <add key="SkipEncryptedEmails" value="true" />
    
    <!-- Replacement text for URLs (not used in current implementation - URLs are kept as plain text) -->
    <add key="UrlReplacementText" value="" />
    
    <!-- URL regex pattern for plain text detection -->
    <add key="UrlPattern" value="https?://[^\s&lt;&gt;&quot;']+" />
    
    <!-- HTML anchor tag regex pattern -->
    <add key="HtmlLinkPattern" value="&lt;a\s+[^&gt;]*href\s*=\s*[&quot;']([^&quot;']*)[&quot;'][^&gt;]*&gt;(.*?)&lt;/a&gt;" />
    
    <!-- Process HTML emails - set to false to only process plain text -->
    <add key="ProcessHtmlEmails" value="true" />
    
    <!-- Process plain text emails - set to false to only process HTML -->
    <add key="ProcessPlainTextEmails" value="true" />
    
    <!-- Agent priority (lower number = higher priority) -->
    <add key="AgentPriority" value="1" />
    
    <!-- Maximum log file size in MB - log will rotate when exceeded -->
    <add key="MaxLogFileSizeMB" value="50" />
  </appSettings>
</configuration>